# Playground environment variables
# Copy this to .env and customize as needed.

# Docker Hub release credentials used by `make tag VERSION=<tag>`.
# Never commit real credentials.
DOCKER_USER=
DOCKER_PAT=

# GitHub Container Registry release credentials used by `make tag VERSION=<tag>`.
GITHUB_USER=your-github-username
GITHUB_PAT=ghp_xxxxxxxxxxxx

MONGO_USER=osionos_user
MONGO_PASS=osionos_pass
MONGO_DB=playground_db
MONGO_PORT=27017

# Leave empty to run in offline mode (no API needed)
VITE_API_URL=

# ── BaaS Connection ────────────────────────────────────────────────────────
# Flip VITE_BAAS_ENABLED=true when the Prismatica stack is running.
VITE_BAAS_ENABLED=false
VITE_BAAS_URL=http://localhost:8000
VITE_BAAS_ANON_KEY=eyJhbGciOiJIUzI1NiJ9...
# Never put BAAS_SERVICE_ROLE_KEY or JWT_SECRET in VITE_ vars.

# ── Shared MongoDB (Phase 3) ───────────────────────────────────────────────
# MONGO_URI=mongodb://osionos_user:osionos_pass@prismatica_mongodb:27017/playground_db?authSource=admin
# Comment out the mongodb service in docker-compose.base.yml when set.

VITE_PORT=3001
APP_PORT=80
SONAR_PORT=9000
