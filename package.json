{
  "name": "osionos-playground",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --fix",
    "test": "pnpm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:serial": "playwright test --workers=1",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:doctor": "node scripts/test-env-doctor.mjs",
    "test:quality": "pnpm run typecheck && pnpm run lint",
    "test:setup": "playwright install chromium && pnpm run test:doctor"
  },
  "dependencies": {
    "@univers42/ui-collection": "^2.5.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.474.0",
    "mermaid": "^11.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.59.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.2.0"
  }
}
