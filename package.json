{
  "name": "notion-playground",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:e2e",
    "test:e2e": "npx playwright test",
    "test:e2e:serial": "npx playwright test --workers=1",
    "test:e2e:smoke": "npx playwright test tests/e2e/smoke",
    "test:quality": "make ci",
    "test:setup": "npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "@univers42/ui-collection": "^2.4.6",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.474.0",
    "mermaid": "^11.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.59.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.2.0"
  }
}
